PROJECT_NAME="Fashion E-Commerce API"
API_V1_PREFIX=/api/v1

# postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fashion_ecommerce

# JWT auth. Generate a real secret for any non-local environment, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=insecure-dev-secret-change-me-before-deploying
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
